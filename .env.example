# Build-time environment variables used by the Vite frontend.
# Keep real values in `.env` or your CI/CD environment, not in committed docs.

VITE_BITCOIN_API=https://your-mainnet-esplora.example.com
VITE_TESTNET4_API=https://your-testnet4-esplora.example.com
VITE_REGTEST_API=http://127.0.0.1:3003

VITE_BITCOIN_WEB_EXPLORER=https://your-mainnet-explorer.example.com
VITE_TESTNET4_WEB_EXPLORER=https://your-testnet4-explorer.example.com
VITE_REGTEST_WEB_EXPLORER=http://127.0.0.1:3003

VITE_RGB_LDK_NODE_IMAGE=bitlightlabs/rln-ldk-node:dev-20260313
